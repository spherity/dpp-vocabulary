        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:StateOfCertifiedEnergyEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "State Of Certified Energy Entity",
        "rdfs:comment": {
            "@value": "<div>State of certified energy value with last update timestamp.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
