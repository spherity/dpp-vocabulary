        "rdfs:domain": "bp:DismantlingandRemovalDocumentation",
        "rdfs:range": "bp:DocumentTypeDatatype",
        "rdfs:label": "document type",
        "rdfs:comment": {
            "@value": "<div>Describes type for document e.g. Dismantling manual</div>",
