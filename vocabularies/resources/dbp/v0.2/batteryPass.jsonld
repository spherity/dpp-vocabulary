    "@id": "https://dpp.vocabulary.spherity.com/dbp/v0.2#",
    "@type": "owl:Ontology",
    "dc:title": {
        "@value": "Battery Digital Product Passport Vocabulary",
        "@language": "en"
    },
    "dc:description": {
        "@value": "Combined Battery Digital Product Passport vocabulary covering all mandatory and optional\ndata attributes required by REGULATION (EU) 2023/1542 (EU Battery Regulation) and\nDIN DKE Spec 99100. Modules included: Carbon Footprint, Circularity, General Information,\nLabels, Material Composition, Performance and Durability, Supply Chain Due Diligence.\n",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
    },
    "rdfs:seeAlso": "https://thebatterypass.eu/battery-pass/",
    "dc:date": "2026-04-20",
    "rdfs_properties": [{
        "@id": "bp:batteryPassportIdentifier",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "bp:BatteryPassportIdentifierDatatype",
        "rdfs:label": "battery passport identifier",
        "rdfs:comment": {
            "@value": "<div>Unique identifier allowing for the unambiguous identification of each individual\nbattery and hence each corresponding battery passport.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:productIdentifier",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "xsd:string",
        "rdfs:label": "product identifier",
        "rdfs:comment": {
            "@value": "<div>Unique identifier allowing for the unambiguous identification of each individual\nbattery and hence each corresponding battery passport.\nDIN DKE Spec chapter reference: 6.1.2.2</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:batteryModelIdentifier",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "xsd:string",
        "rdfs:label": "battery model identifier",
        "rdfs:comment": {
            "@value": "<div>Unambiguous identification of the battery model.\nDIN DKE Spec chapter reference: 6.1.2.1</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:batterySerialNumber",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "xsd:string",
        "rdfs:label": "battery serial number",
        "rdfs:comment": {
            "@value": "<div>Unique serial number of the individual battery item.\nDIN DKE Spec chapter reference: 6.1.2.2</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:batteryCategory",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "bp:BatteryCategoryDatatype",
        "rdfs:label": "battery category",
        "rdfs:comment": {
            "@value": "<div>Categories relevant for the battery passport: LMT battery, electric vehicle battery,\nstationary or other industrial battery greater than 2 kWh.\nDIN DKE Spec chapter reference: 6.1.3.5</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:batteryMass",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "xsd:double",
        "rdfs:label": "battery mass",
        "rdfs:comment": {
            "@value": "<div>Mass of the entire battery in kilograms.\nDIN DKE Spec chapter reference: 6.1.3.6</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:batteryStatus",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "bp:BatteryStatusDatatype",
        "rdfs:label": "battery status",
        "rdfs:comment": {
            "@value": "<div>Lifecycle status of the battery. Status defined from a list: original, repurposed,\nreused, remanufactured, waste.\nDIN DKE Spec chapter reference: 6.1.3.7</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:manufacturingDate",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "xsd:gYearMonth",
        "rdfs:label": "manufacturing date",
        "rdfs:comment": {
            "@value": "<div>The manufacturing date should not only relate to the battery model, but to the\nbattery item. The date code should comply with DIN ISO 8601.\nDIN DKE Spec chapter reference: 6.1.3.2</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:puttingIntoService",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "xsd:gYearMonth",
        "rdfs:label": "putting into service",
        "rdfs:comment": {
            "@value": "<div>The battery passport must include information on the date of putting the battery\ninto service. DIN DKE Spec chapter reference: 6.1.3.3</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:warrantyPeriod",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "xsd:gYearMonth",
        "rdfs:label": "warranty period",
        "rdfs:comment": {
            "@value": "<div>The battery passport must include information about the period for which the\ncommercial warranty applies. DIN DKE Spec chapter reference: 6.1.3.4</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:manufacturerInformation",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "bp:ContactInformation",
        "rdfs:label": "manufacturer information",
        "rdfs:comment": {
            "@value": "<div>Unambiguous identification of the manufacturer of the battery, suggested via\na unique operator identifier. DIN DKE Spec chapter reference: 6.1.2.4</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:operatorInformation",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "bp:ContactInformation",
        "rdfs:label": "operator information",
        "rdfs:comment": {
            "@value": "<div>State the name, trade name or mark, postal address, web address, e-mail address.\nDIN DKE Spec chapter reference: 6.1.2.3</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:manufacturerIdentifier",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "xsd:string",
        "rdfs:label": "manufacturer identifier",
        "rdfs:comment": {
            "@value": "<div>Unique identifier of the manufacturer of the battery.\nDIN DKE Spec chapter reference: 6.1.2.4</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:economicOperatorIdentifier",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "xsd:string",
        "rdfs:label": "economic operator identifier",
        "rdfs:comment": {
            "@value": "<div>Unique identifier of the economic operator responsible for placing the battery\non the market. DIN DKE Spec chapter reference: 6.1.2.3</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:manufacturingPlace",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:GeneralInformation",
        "rdfs:range": "bp:PostalAddress",
        "rdfs:label": "manufacturing place",
        "rdfs:comment": {
            "@value": "<div>Unambiguous identification of the manufacturing facility.\nDIN DKE Spec chapter reference: 6.1.3.1</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:dppSchemaVersion",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:DPPStaticMetadata",
        "rdfs:range": "xsd:string",
        "rdfs:label": "dpp schema version",
        "rdfs:comment": {
            "@value": "<div>Version of the DPP data schema in use, as defined in JTC-24 prEN_18223.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:dppGranularity",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:DPPStaticMetadata",
        "rdfs:range": "xsd:string",
        "rdfs:label": "dpp granularity",
        "rdfs:comment": {
            "@value": "<div>Level of granularity at which the DPP is issued (e.g. model, batch, item),\nas defined in JTC-24 prEN_18223.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:dppStatus",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:DPPStatus",
        "rdfs:range": "bp:DPPStatusDatatype",
        "rdfs:label": "dpp status",
        "rdfs:comment": {
            "@value": "<div>Dynamic lifecycle state of the Digital Product Passport record.\nChanges independently of product data over the DPP lifecycle.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:dppLastUpdated",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:DPPLastUpdated",
        "rdfs:range": "xsd:dateTime",
        "rdfs:label": "dpp last updated",
        "rdfs:comment": {
            "@value": "<div>Timestamp of the most recent update to the Digital Product Passport record.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:contactName",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:ContactInformation",
        "rdfs:range": "xsd:string",
        "rdfs:label": "contact name",
        "rdfs:comment": {
            "@value": "<div>Name of the contact or organisation. Used to represent the company name\nof manufacturer or operator.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:identifier",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:ContactInformation",
        "rdfs:range": "xsd:string",
        "rdfs:label": "identifier",
        "rdfs:comment": {
            "@value": "<div>Economic operator code identifier.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:emailAddress",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:ContactInformation",
        "rdfs:range": "bp:EmailAddressDatatype",
        "rdfs:label": "email address",
        "rdfs:comment": {
            "@value": "<div>Email address.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:webAddress",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:ContactInformation",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "web address",
        "rdfs:comment": {
            "@value": "<div>Web address.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:postalAddress",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:ContactInformation",
        "rdfs:range": "bp:PostalAddress",
        "rdfs:label": "postal address",
        "rdfs:comment": {
            "@value": "<div>Postal address of the contact.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:addressCountry",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:PostalAddress",
        "rdfs:range": "xsd:string",
        "rdfs:label": "address country",
        "rdfs:comment": {
            "@value": "<div>The country. For example, Germany or DE.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:postalCode",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:PostalAddress",
        "rdfs:range": "xsd:string",
        "rdfs:label": "postal code",
        "rdfs:comment": {
            "@value": "<div>The postal code. For example, DE-10719 or 10719.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:streetAddress",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:PostalAddress",
        "rdfs:range": "xsd:string",
        "rdfs:label": "street address",
        "rdfs:comment": {
            "@value": "<div>The street address. For example, Street 1 or Hindenburgstr. 10.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:facilityIdentifier",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:PostalAddress",
        "rdfs:range": "xsd:string",
        "rdfs:label": "facility identifier",
        "rdfs:comment": {
            "@value": "<div>Unique identifier of the manufacturing facility.\nDIN DKE Spec chapter reference: 6.1.3.1</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:labels",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:Labeling",
        "rdfs:range": "bp:Label",
        "rdfs:label": "labels",
        "rdfs:comment": {
            "@value": "<div>Separate collection or WEEE label indicating that a product should not be\ndiscarded as unsorted waste but must be sent to separate collection facilities\nfor recovery and recycling.\nDIN DKE Spec chapter reference: 6.2.2-6.2.5</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:declarationOfConformity",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:Labeling",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "declaration of conformity",
        "rdfs:comment": {
            "@value": "<div>A battery passport must include the EU declaration of conformity.\nThe EU declaration of conformity has the model structure set out in Annex IX.\nDIN DKE Spec chapter reference: 6.2.7</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:resultOfTestReport",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:Labeling",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "result of test report",
        "rdfs:comment": {
            "@value": "<div>URL to a document that includes results of test reports proving compliance\nin the market conformity assessment procedure.\nDIN DKE Spec chapter reference: 6.2.8</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:extinguishingAgent",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:Labeling",
        "rdfs:range": "xsd:string",
        "rdfs:label": "extinguishing agent",
        "rdfs:comment": {
            "@value": "<div>Usable extinguishing agents referring to classes of extinguishers (A, B, C, D, K).\nDIN DKE Spec chapter reference: 6.2.5</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:symbol",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:Label",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "symbol",
        "rdfs:comment": {
            "@value": "<div>URL or path to the labeling symbol image.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:meaning",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:Label",
        "rdfs:range": "xsd:string",
        "rdfs:label": "meaning",
        "rdfs:comment": {
            "@value": "<div>Explanation of the meaning of all symbols and labels (including separate\ncollection; cadmium and lead; and carbon footprint and carbon footprint\nperformance class symbols).</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:subject",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:Label",
        "rdfs:range": "bp:LabelingSubjectDatatype",
        "rdfs:label": "subject",
        "rdfs:comment": {
            "@value": "<div>Short name of required labeling subjects.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:batteryCarbonFootprint",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:CarbonFootprint",
        "rdfs:range": "xsd:double",
        "rdfs:label": "battery carbon footprint",
        "rdfs:comment": {
            "@value": "<div>The carbon footprint of the battery, calculated as kg of carbon dioxide equivalent\nper one kWh of the total energy provided by the battery over its expected service life,\nas declared in the Carbon Footprint Declaration.\nDIN DKE Spec 99100 chapter reference: 6.3.2</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:carbonFootprintPerformanceClass",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:CarbonFootprint",
        "rdfs:range": "bp:CarbonFootprintPerformanceClassDatatype",
        "rdfs:label": "carbon footprint performance class",
        "rdfs:comment": {
            "@value": "<div>The carbon footprint performance class that the relevant battery model per\nmanufacturing plant corresponds to.\nDIN DKE Spec 99100 chapter reference: 6.3.7</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:carbonFootprintStudy",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:CarbonFootprint",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "carbon footprint study",
        "rdfs:comment": {
            "@value": "<div>A web link to get access to a public version of the study supporting\nthe carbon footprint values.\nDIN DKE Spec 99100 chapter reference: 6.3.8</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:absoluteCarbonFootprint",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:CarbonFootprint",
        "rdfs:range": "xsd:integer",
        "rdfs:label": "absolute carbon footprint",
        "rdfs:comment": {
            "@value": "<div>The battery carbon footprint in absolute terms, calculated as kilograms of\ncarbon dioxide equivalent, without reference to the functional unit.\nDIN DKE Spec 99100 chapter reference: 6.3.10</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:carbonFootprintPerLifecycleStage",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:CarbonFootprint",
        "rdfs:range": "bp:CarbonFootprintPerLifecycleStage",
        "rdfs:label": "carbon footprint per lifecycle stage",
        "rdfs:comment": {
            "@value": "<div>The carbon footprint of the battery as share of total Battery Carbon Footprint,\ndifferentiated per life cycle stages raw material extraction, battery production,\ndistribution and recycling.\nDIN DKE Spec 99100 chapter reference: 6.3.3-6.3.6</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:carbonFootprint",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:CarbonFootprintPerLifecycleStage",
        "rdfs:range": "xsd:double",
        "rdfs:label": "carbon footprint",
        "rdfs:comment": {
            "@value": "<div>Carbon footprint of the individual lifecycle stage.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
