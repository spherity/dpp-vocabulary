        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:RemainingCapacityEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Remaining Capacity Entity",
