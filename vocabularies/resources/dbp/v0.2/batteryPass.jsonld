    "rdfs_datatypes": [{
        "@id": "bp:BatteryCategoryDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "LMT|EV|SLI|Stationary"
            }]
        },
        "rdfs:label": "Battery Category",
        "rdfs:comment": {
            "@value": "<div>The category of the battery as defined by REGULATION (EU) 2023/1542.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryComponentDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "Pack|Module|Cell"
            }]
        },
        "rdfs:label": "Battery Component",
        "rdfs:comment": {
            "@value": "<div>Identifies a battery component level for measurements such as internal resistance.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryComponentTypeDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "Cathode|Anode|Electrolyte|Cell|Module|Pack|Other"
            }]
        },
        "rdfs:label": "Battery Component Type",
        "rdfs:comment": {
            "@value": "<div>Type classification of the battery component (e.g. Cathode, Anode, Electrolyte).</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryPassportIdentifierDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "^urn:[a-z0-9]+:[a-z0-9]+$"
            }]
        },
        "rdfs:label": "Battery Passport Identifier",
        "rdfs:comment": {
            "@value": "<div>URN format identifier for battery passport.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryStatusDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "Original|Repurposed|Reused|Remanufactured|Waste"
            }]
        },
        "rdfs:label": "Battery Status",
        "rdfs:comment": {
            "@value": "<div>Lifecycle status of the battery as defined in REGULATION (EU) 2023/1542.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:CASNumberDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "^\\d{2,7}-\\d{2}-\\d{1}$"
            }]
        },
        "rdfs:label": "CAS Number",
        "rdfs:comment": {
            "@value": "<div>Chemical Abstracts Service (CAS) Registry Number format.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:CarbonFootprintPerformanceClassDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "A|B|C|D|E"
            }]
        },
        "rdfs:label": "Carbon Footprint Performance Class",
        "rdfs:comment": {
            "@value": "<div>The carbon footprint performance class of the battery as defined in\nREGULATION (EU) 2023/1542, ranging from A (lowest/best) to E (highest/worst).</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:DPPStatusDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "Active|Archived|Inactive|Marked-for-deletion"
            }]
        },
        "rdfs:label": "DPP Status",
        "rdfs:comment": {
            "@value": "<div>Lifecycle status of the Digital Product Passport.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:DocumentTypeDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "BillOfMaterial|Model3D|DismantlingManual|RemovalManual|OtherManual|Drawing"
            }]
        },
        "rdfs:label": "Document Type",
        "rdfs:comment": {
            "@value": "<div>Enumeration of document types for dismantling and removal documentation.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:EmailAddressDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "^[\\w.-]+@[\\w.-]+\\.[A-Za-z]{2,}$"
            }]
        },
        "rdfs:label": "Email Address",
        "rdfs:comment": {
            "@value": "<div>Valid email address format.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:HazardousSubstanceClassDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "AcuteToxicity|SkinCorrosionOrIrritation|EyeDamageOrIrritation|RespiratoryOrSkinSensitisation|GermCellMutagenicity|Carcinogenicity|ReproductiveToxicity|SpecificTargetOrganToxicitySingleExposure|SpecificTargetOrganToxicityRepeatedExposure|AspirationHazard|AquaticToxicityAcute|AquaticToxicityChronic"
            }]
        },
        "rdfs:label": "Hazardous Substance Class",
        "rdfs:comment": {
            "@value": "<div>Enumeration of CLP hazard classes per Regulation (EC) No 1272/2008.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:LabelingSubjectDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "SeparateCollection|Cadmium|Lead|CarbonFootprint|ExtinguishingAgent"
            }]
        },
        "rdfs:label": "Labeling Subject",
        "rdfs:comment": {
            "@value": "<div>Short name of required labeling subjects as specified in REGULATION (EU) 2023/1542.\nCadmium and Lead are listed as separate options.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:LifecycleStageDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "RawMaterialAcquisition|MainProduction|Distribution|Use|EndOfLifeAndRecycling"
            }]
        },
        "rdfs:label": "Lifecycle Stage",
        "rdfs:comment": {
            "@value": "<div>Enumeration of battery lifecycle stages for carbon footprint attribution.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:PercentageDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:double"],
        "rdfs:label": "Percentage",
        "rdfs:comment": {
            "@value": "<div>Percentage value between 0 and 100.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:RecycledMaterialDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "Cobalt|Nickel|Lithium|Lead"
            }]
        },
        "rdfs:label": "Recycled Material",
        "rdfs:comment": {
            "@value": "<div>Name of recyclable material in recycled content reporting.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:TemperatureConstraintDatatype",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "StorageTemperature|ChargingTemperature"
            }]
        },
        "rdfs:label": "Temperature Constraint",
        "rdfs:comment": {
            "@value": "<div>Constraint type for battery temperature ranges, specifying the use case\nfor the temperature limit.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
