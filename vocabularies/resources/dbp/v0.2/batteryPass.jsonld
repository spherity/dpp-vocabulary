        "rdfs:domain": "bp:NegativeEvent",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "information on accidents",
        "rdfs:comment": {
            "@value": "<div>URL to information on accidents or incidents related to the battery.\nDIN DKE Spec 99100 chapter reference: 6.7.7.11</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:timeExtremeHighTemp",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:TemperatureConditions",
        "rdfs:range": "xsd:double",
        "rdfs:label": "time extreme high temp",
        "rdfs:comment": {
            "@value": "<div>Cumulated time spent above upper temperature boundary.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:timeExtremeLowTemp",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:TemperatureConditions",
        "rdfs:range": "xsd:double",
        "rdfs:label": "time extreme low temp",
        "rdfs:comment": {
            "@value": "<div>Cumulated time spent below lower temperature boundary.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:timeExtremeHighTempCharging",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:TemperatureConditions",
        "rdfs:range": "xsd:double",
        "rdfs:label": "time extreme high temp charging",
        "rdfs:comment": {
            "@value": "<div>Cumulated time spent above upper temperature boundary during charging.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:timeExtremeLowTempCharging",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:TemperatureConditions",
        "rdfs:range": "xsd:double",
        "rdfs:label": "time extreme low temp charging",
        "rdfs:comment": {
            "@value": "<div>Cumulated time spent below lower temperature boundary during charging.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:temperatureValue",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:TemperatureConditions",
        "rdfs:range": "xsd:double",
        "rdfs:label": "temperature value",
        "rdfs:comment": {
            "@value": "<div>Recorded temperature value in degrees Celsius for operating environmental conditions.\nDIN DKE Spec 99100 chapter reference: 6.7.7.2</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:lastUpdate",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:BatteryCondition",
        "rdfs:range": "xsd:dateTime",
        "rdfs:label": "last update",
        "rdfs:comment": {
            "@value": "<div>Timestamp for dynamic data attributes showing the last update time.\nApplied to all dynamic condition entities.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }],
    "rdfs_classes": [{
        "@id": "bp:GeneralInformation",
        "@type": "rdfs:Class",
        "rdfs:label": "General Information",
        "rdfs:comment": {
            "@value": "<div>General product information for battery passport including product identification,\nmanufacturer information, manufacturing details, and battery category.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://eur-lex.europa.eu/legal-content/EN/TXT/PDF/?uri=CELEX:32023R1542"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:DPPStaticMetadata",
        "@type": "rdfs:Class",
        "rdfs:label": "DPP Static Metadata",
        "rdfs:comment": {
            "@value": "<div>Static Digital Product Passport metadata as defined in JTC-24 prEN_18223.\nThese attributes are set at issuance and describe the structure and granularity\nof the DPP record itself.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://www.din.de/en/getting-involved/standards-committees/nid/european-projects/wdc-proj:din21:355350326"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:DPPStatus",
        "@type": "rdfs:Class",
        "rdfs:label": "DPP Status",
        "rdfs:comment": {
            "@value": "<div>Dynamic lifecycle state of the Digital Product Passport record.\nThis attribute changes over the DPP lifecycle independently of the static product data.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://www.din.de/en/getting-involved/standards-committees/nid/european-projects/wdc-proj:din21:355350326"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:DPPLastUpdated",
        "@type": "rdfs:Class",
        "rdfs:label": "DPP Last Updated",
        "rdfs:comment": {
            "@value": "<div>Dynamic timestamp recording when the Digital Product Passport record was most\nrecently updated. Changes independently of static product data over the DPP lifecycle.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://www.din.de/en/getting-involved/standards-committees/nid/european-projects/wdc-proj:din21:355350326"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:ContactInformation",
        "@type": "rdfs:Class",
        "rdfs:label": "Contact Information",
        "rdfs:comment": {
            "@value": "<div>Contact information including name, postal address, identifier,\nand optional email and web address.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:PostalAddress",
        "@type": "rdfs:Class",
        "rdfs:label": "Postal Address",
        "rdfs:comment": {
            "@value": "<div>A postal address with country, postal code, street address,\nand optional facility identifier.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://schema.org/PostalAddress"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:Labeling",
        "@type": "rdfs:Class",
        "rdfs:label": "Labeling",
        "rdfs:comment": {
            "@value": "<div>Battery labeling information including declaration of conformity,\ntest reports, labels, and extinguishing agent.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://eur-lex.europa.eu/legal-content/EN/TXT/PDF/?uri=CELEX:32023R1542"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:Label",
        "@type": "rdfs:Class",
        "rdfs:label": "Label",
        "rdfs:comment": {
            "@value": "<div>Entity for the definition of required battery labeling including\nsymbol, meaning, and subject.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:CarbonFootprint",
        "@type": "rdfs:Class",
        "rdfs:label": "Carbon Footprint",
        "rdfs:comment": {
            "@value": "<div>The battery passport must contain carbon footprint per functional unit of the\nbattery as declared in the battery carbon footprint declaration in accordance\nwith the entry into force of the implementing acts on the format of declaration.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://eur-lex.europa.eu/legal-content/EN/TXT/PDF/?uri=CELEX:32023R1542"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:CarbonFootprintPerLifecycleStage",
        "@type": "rdfs:Class",
        "rdfs:label": "Carbon Footprint Per Lifecycle Stage",
        "rdfs:comment": {
            "@value": "<div>The carbon footprint of the battery as share of total Battery Carbon Footprint,\ndifferentiated per life cycle stage: raw material acquisition, main production,\ndistribution and end of life and recycling.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:SupplyChainDueDiligence",
        "@type": "rdfs:Class",
        "rdfs:label": "Supply Chain Due Diligence",
        "rdfs:comment": {
            "@value": "<div>Battery supply chain due diligence information including responsible sourcing\nreports and third-party assurances.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://eur-lex.europa.eu/legal-content/EN/TXT/PDF/?uri=CELEX:32023R1542"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:MaterialComposition",
        "@type": "rdfs:Class",
        "rdfs:label": "Material Composition",
        "rdfs:comment": {
            "@value": "<div>Battery material composition including battery chemistry, battery materials,\nand hazardous substances.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://eur-lex.europa.eu/legal-content/EN/TXT/PDF/?uri=CELEX:32023R1542"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryChemistry",
        "@type": "rdfs:Class",
        "rdfs:label": "Battery Chemistry",
        "rdfs:comment": {
            "@value": "<div>Detailed composition, including materials used in the cathode, anode,\nand electrolyte. All common cells have two electrodes and an electrolyte.\nThe specific combination of materials used to make these components is called\nchemistry.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryMaterial",
        "@type": "rdfs:Class",
        "rdfs:label": "Battery Material",
        "rdfs:comment": {
            "@value": "<div>Detailed composition, including materials used in the cathode, anode,\nand electrolyte.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryLocation",
        "@type": "rdfs:Class",
        "rdfs:label": "Battery Location",
        "rdfs:comment": {
            "@value": "<div>Battery component that includes the material, identified by component name,\nidentifier, and component type.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:HazardousSubstance",
        "@type": "rdfs:Class",
        "rdfs:label": "Hazardous Substance",
        "rdfs:comment": {
            "@value": "<div>Hazardous substances contained in the battery other than mercury, cadmium or lead.\nSubstance as a chemical element and its compounds in the natural state or the\nresult of a manufacturing process.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:HazardousSubstanceImpact",
        "@type": "rdfs:Class",
        "rdfs:label": "Hazardous Substance Impact",
        "rdfs:comment": {
            "@value": "<div>An environmental or health impact associated with a hazardous substance,\ndescribed by an impact class and impact statement based on REACH or GHS\nfor all hazard classes applicable to substances in the battery.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:Circularity",
        "@type": "rdfs:Class",
        "rdfs:label": "Circularity",
        "rdfs:comment": {
            "@value": "<div>Battery circularity information including dismantling, spare parts,\nrecycled content, safety measures, and end-of-life information.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://eur-lex.europa.eu/legal-content/EN/TXT/PDF/?uri=CELEX:32023R1542"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:DismantlingDocument",
        "@type": "rdfs:Class",
        "rdfs:label": "Dismantling Document",
        "rdfs:comment": {
            "@value": "<div>Dismantling and Removal information, including at least: exploded diagrams\nof the battery system/pack showing the location of battery cells, disassembly\nsequences, type and number of fastening techniques to be unlocked, tools required\nfor disassembly, warnings if risk of damaging parts exists, amount of cells used\nand layout.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:SparePartSupplier",
        "@type": "rdfs:Class",
        "rdfs:label": "Spare Part Supplier",
        "rdfs:comment": {
            "@value": "<div>The part numbers for components should be provided together with the postal\naddress, e-mail address and web address of the sources for spare parts.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:Component",
        "@type": "rdfs:Class",
        "rdfs:label": "Component",
        "rdfs:comment": {
            "@value": "<div>Component information including part name and number.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:RecycledContent",
        "@type": "rdfs:Class",
        "rdfs:label": "Recycled Content",
        "rdfs:comment": {
            "@value": "<div>A battery passport must include recycled content information. The content\ninformation must include the percentage share of materials that have been\nrecovered from battery manufacturing waste, for each battery model per year\nand per manufacturing plant.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:EndOfLifeInformation",
        "@type": "rdfs:Class",
        "rdfs:label": "End Of Life Information",
        "rdfs:comment": {
            "@value": "<div>Information on end-of-life handling, waste prevention, and collection.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:PerformanceAndDurability",
        "@type": "rdfs:Class",
        "rdfs:label": "Performance And Durability",
        "rdfs:comment": {
            "@value": "<div>Battery performance and durability information including technical properties\nand condition.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://eur-lex.europa.eu/legal-content/EN/TXT/PDF/?uri=CELEX:32023R1542"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryTechnicalProperties",
        "@type": "rdfs:Class",
        "rdfs:label": "Battery Technical Properties",
        "rdfs:comment": {
            "@value": "<div>Covers all capability related static data attributes including rated capacity,\npower, energy, voltage ranges, internal resistance, expected lifetime, and\nallowable degradation thresholds.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryCondition",
        "@type": "rdfs:Class",
        "rdfs:label": "Battery Condition",
        "rdfs:comment": {
            "@value": "<div>Covers all battery lifetime relevant dynamic properties including energy throughput,\nnumber of cycles, state of charge, and temperature information.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:PowerCapabilityAt",
        "@type": "rdfs:Class",
        "rdfs:label": "Power Capability At",
        "rdfs:comment": {
            "@value": "<div>Power capability measurement at a specific state of charge percentage.\nUsed to characterise battery power output across its operating range.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:InternalResistance",
        "@type": "rdfs:Class",
        "rdfs:label": "Internal Resistance",
        "rdfs:comment": {
            "@value": "<div>Internal resistance measurement for battery pack, module, or cell level.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:TemperatureRangeType",
        "@type": "rdfs:Class",
        "rdfs:label": "Temperature Range Type",
        "rdfs:comment": {
            "@value": "<div>Temperature range with minimum and maximum boundaries.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:StateOfCharge",
        "@type": "rdfs:Class",
        "rdfs:label": "State Of Charge",
        "rdfs:comment": {
            "@value": "<div>Available capacity in a battery expressed as a percentage of remaining capacity.\nDIN DKE Spec 99100 chapter reference: 6.7.2.8</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:RemainingCapacity",
        "@type": "rdfs:Class",
        "rdfs:label": "Remaining Capacity",
        "rdfs:comment": {
            "@value": "<div>In-use data attribute on capacity, corresponding with definition of rated capacity.\nDIN DKE Spec 99100 chapter reference: 6.7.2.3</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:RemainingEnergy",
        "@type": "rdfs:Class",
        "rdfs:label": "Remaining Energy",
        "rdfs:comment": {
            "@value": "<div>Energy supplied by the battery from beginning of test procedure until\nbreak-off criterion is reached. DIN DKE Spec 99100 chapter reference: 6.7.2.6</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:StateOfCertifiedEnergy",
        "@type": "rdfs:Class",
        "rdfs:label": "State Of Certified Energy",
        "rdfs:comment": {
            "@value": "<div>Measured or on-board UBE performance as percentage of certified usable battery energy.\nDIN DKE Spec 99100 chapter reference: 6.7.2.7</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:RemainingPowerCapability",
        "@type": "rdfs:Class",
        "rdfs:label": "Remaining Power Capability",
        "rdfs:comment": {
            "@value": "<div>Remaining power capability with temperature range when relevant.\nDIN DKE Spec 99100 chapter reference: 6.7.3.3</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
