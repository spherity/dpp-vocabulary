        "rdfs:label": "symbol",
        "rdfs:comment": {
            "@value": "<div>Symbol representation of the unit</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:commonCode",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:Unit",
        "rdfs:range": "xsd:string",
        "rdfs:label": "common code",
        "rdfs:comment": {
            "@value": "<div>Common code representation of the unit</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:referenceUnit",
        "@type": "rdf:Property",
        "rdfs:domain": "bp:Unit",
        "rdfs:label": "reference unit",
        "rdfs:comment": {
            "@value": "<div>Reference to a standard unit definition</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:dismantlingAndRemovalInformation",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:Circularity",
        "rdfs:range": "bp:DismantlingandRemovalDocumentation",
        "rdfs:label": "dismantling and removal information",
        "rdfs:comment": {
            "@value": "<div>Dismantling and Removal information. DIN DKE Spec 99100 chapter reference: 6.6.1.2</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:sparePartSources",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:Circularity",
        "rdfs:range": "bp:SparePartSupplierEntity",
        "rdfs:label": "spare part sources",
        "rdfs:comment": {
            "@value": "<div>Contact details of sources for replacement spares. DIN DKE Spec 99100 chapter reference: 6.6.1.3 - 6.6.1.4</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:recycledContent",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:Circularity",
        "rdfs:range": "bp:RecycledContentEntity",
        "rdfs:label": "recycled content",
        "rdfs:comment": {
            "@value": "<div>Share of material recovered from waste present in active materials for each battery model per year and per manufacturing plant. DIN DKE Spec 99100 chapter reference: 6.6.2.3 - 6.6.2.10</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:safetyMeasures",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:Circularity",
        "rdfs:range": "bp:SafetyMeasuresEntity",
        "rdfs:label": "safety measures",
        "rdfs:comment": {
            "@value": "<div>Safety measures and instructions should also take past negative and extreme events as well as the separate data attributes 'battery status' and 'battery composition/chemistry' into account. DIN DKE Spec 99100 chapter reference: 6.6.1.5</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:endOfLifeInformation",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:Circularity",
        "rdfs:range": "bp:EndOfLifeInformationEntity",
        "rdfs:label": "end of life information",
        "rdfs:comment": {
            "@value": "<div>Producer or producer responsibility organisations shall make information available to distributors and end-users on the role of end-users in contributing to waste prevention. DIN DKE Spec 99100 chapter reference: 6.6.3.2 - 6.6.3.4</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:addressOfSupplier",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:SparePartSupplierEntity",
        "rdfs:range": "bp:PostalAddress",
        "rdfs:label": "address of supplier",
        "rdfs:comment": {
            "@value": "<div>Postal address of supplier for spare parts.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:components",
        "@type": ["rdf:Property", "owl:ObjectProperty"],
        "rdfs:domain": "bp:SparePartSupplierEntity",
        "rdfs:range": "bp:ComponentEntity",
        "rdfs:label": "components",
        "rdfs:comment": {
            "@value": "<div>Components available at supplier</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:renewableContent",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:Circularity",
        "rdfs:range": "xsd:float",
        "rdfs:label": "renewable content",
        "rdfs:comment": {
            "@value": "<div>Share of renewable material content. A renewable material is a material made of natural resources that can be replenished. DIN DKE Spec 99100 chapter reference: 6.6.2.11</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
