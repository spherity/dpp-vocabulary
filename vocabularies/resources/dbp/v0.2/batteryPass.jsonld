            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:supplyChainDueDiligenceReport",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:SupplyChainDueDiligence",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "supply chain due diligence report",
        "rdfs:comment": {
            "@value": "<div>The battery passport must include information on responsible sourcing as indicated\nin the report on its due diligence policy. The report must provide data on: supply\nchain due diligence policy, risk management plan, summary report of third-party\nverification, and elaboration on access to information.\nDIN DKE Spec 99100 chapter reference: 6.4.2</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:thirdPartyAssurances",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:SupplyChainDueDiligence",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "third party assurances",
        "rdfs:comment": {
            "@value": "<div>Information on third-party supply chain assurances such as certifications,\nof recognised supply chain schemes.\nDIN DKE Spec 99100 chapter reference: 6.4.3</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:supplyChainIndices",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:SupplyChainDueDiligence",
        "rdfs:range": "xsd:string",
        "rdfs:label": "supply chain indices",
        "rdfs:comment": {
            "@value": "<div>Supply chain indices to allow easy assessment for consumers on level of\nresponsible sourcing. ESGE+ indices under development by the GBA (Global\nBattery Alliance), scoring and benchmarking sustainability performance.\nDIN DKE Spec 99100 chapter reference: 6.4.4</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
