        "rdfs:domain": "bp:SafetyMeasuresEntity",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "safety instructions",
        "rdfs:comment": {
            "@value": "<div>Safety measures and necessary safety instructions to handle waste batteries, including in relation to the risks associated with, and the handling of, batteries containing lithium.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
