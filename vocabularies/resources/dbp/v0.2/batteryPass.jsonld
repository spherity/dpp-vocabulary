        }]
    }, {
        "@id": "bp:rPCLastUpdated",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:RemainingPowerCapabilityDynamicAt",
        "rdfs:range": "xsd:dateTimeStamp",
        "rdfs:label": "rpc last updated",
        "rdfs:comment": {
            "@value": "<div>Timestamp for remaining power capability last update.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:lastUpdate",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:range": "xsd:dateTimeStamp",
        "rdfs:label": "last update",
        "rdfs:comment": {
            "@value": "<div>Timestamp for dynamic data attributes showing the last update time.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:supplyChainDueDiligenceReport",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:SupplyChainDueDiligence",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "supply chain due diligence report",
        "rdfs:comment": {
            "@value": "<div>The battery passport must include information on responsible sourcing as indicated in the report on its due diligence policy. The report must provide data on: supply chain due diligence policy, risk management plan, summary report of third-party verification, and elaboration on access to information. DIN DKE Spec 99100 chapter reference: 6.4.2</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:thirdPartyAssurances",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:SupplyChainDueDiligence",
        "rdfs:range": "xsd:anyURI",
        "rdfs:label": "third party assurances",
        "rdfs:comment": {
            "@value": "<div>Information on third-party supply chain assurances such as certifications, of recognised supply chain schemes. DIN DKE Spec 99100 chapter reference: 6.4.3</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:supplyChainIndices",
        "@type": ["rdf:Property", "owl:DatatypeProperty"],
        "rdfs:domain": "bp:SupplyChainDueDiligence",
        "rdfs:range": "xsd:string",
        "rdfs:label": "supply chain indices",
        "rdfs:comment": {
            "@value": "<div>Supply chain indices to allow easy assessment for consumers on level of responsible sourcing. ESGE+ indices under development by the GBA (Global Battery Alliance), scoring and benchmarking sustainability performance. DIN DKE Spec 99100 chapter reference: 6.4.4</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }],
    "rdfs_classes": [{
        "@id": "bp:CarbonFootprintForBatteries",
        "@type": "rdfs:Class",
        "rdfs:label": "Carbon Footprint for Batteries",
        "rdfs:comment": {
            "@value": "<div>The battery passport must contain carbon footprint per functional unit of the battery as declared in the battery carbon footprint declaration in accordance with the entry into force of the implementing acts on the format of declaration. Reference: REGULATION (EU) 2023/1542 aka EU Battery Regulation</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://eur-lex.europa.eu/legal-content/EN/TXT/PDF/?uri=CELEX:32023R1542"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:CarbonFootprintPerLifecycleStageEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Carbon Footprint Per Lifecycle Stage Entity",
        "rdfs:comment": {
            "@value": "<div>The carbon footprint of the battery as share of total Battery Carbon Footprint, differentiated per life cycle stage raw material extraction, main production, distribution and end of life and recycling.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:Unit",
        "@type": "rdfs:Class",
        "rdfs:label": "Unit",
        "rdfs:comment": {
            "@value": "<div>Class for units of measurement</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:Circularity",
        "@type": "rdfs:Class",
        "rdfs:label": "Circularity",
        "rdfs:comment": {
            "@value": "<div>Battery circularity information including dismantling, spare parts, recycled content, safety measures, and end-of-life information.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:DismantlingandRemovalDocumentation",
        "@type": "rdfs:Class",
        "rdfs:label": "Dismantling and Removal Documentation",
        "rdfs:comment": {
            "@value": "<div>Dismantling and Removal information, including at least: Exploded diagrams of the battery system/pack showing the location of battery cells, disassembly sequences, type and number of fastening techniques to be unlocked, tools required for disassembly, warnings if risk of damaging parts exists, amount of cells used and layout.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:SparePartSupplierEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Spare Part Supplier Entity",
        "rdfs:comment": {
            "@value": "<div>The part numbers for components should be provided together with the postal address, e-mail address and web address of the sources for spare parts.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:RecycledContentEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Recycled Content Entity",
        "rdfs:comment": {
            "@value": "<div>A battery passport must include recycled content information. The content information must include the percentage share of materials that have been recovered from battery manufacturing waste, for each battery model per year and per manufacturing plant.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:SafetyMeasuresEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Safety Measures Entity",
        "rdfs:comment": {
            "@value": "<div>The safety measures should be provided via the instruction manual as URL linking to PDF.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:EndOfLifeInformationEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "End Of Life Information Entity",
        "rdfs:comment": {
            "@value": "<div>Information on end-of-life handling, waste prevention, and collection.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:PostalAddress",
        "@type": "rdfs:Class",
        "rdfs:label": "Postal Address",
        "rdfs:comment": {
            "@value": "<div>A postal address.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://schema.org/PostalAddress"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:ComponentEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Component Entity",
        "rdfs:comment": {
            "@value": "<div>Component information including part name and number.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:GeneralProductInformation",
        "@type": "rdfs:Class",
        "rdfs:label": "General Product Information",
        "rdfs:comment": {
            "@value": "<div>General product information for battery passport including product identification, manufacturer information, manufacturing details, and battery category.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:ContactInformationEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Contact Information Entity",
        "rdfs:comment": {
            "@value": "<div>Contact information including name, postal address, identifier, and optional email and web address.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:PostalAddressEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Postal Address Entity",
        "rdfs:comment": {
            "@value": "<div>A postal address with country, postal code, and street address.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "rdfs:seeAlso": ["https://schema.org/PostalAddress"],
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:Labeling",
        "@type": "rdfs:Class",
        "rdfs:label": "Labeling",
        "rdfs:comment": {
            "@value": "<div>Battery labeling information including declaration of conformity, test reports, and labels.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:LabelingEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Labeling Entity",
        "rdfs:comment": {
            "@value": "<div>Entity for the definition of required battery labeling including symbol, meaning, and subject.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:MaterialComposition",
        "@type": "rdfs:Class",
        "rdfs:label": "Material Composition",
        "rdfs:comment": {
            "@value": "<div>Battery material composition including battery chemistry, battery materials, and hazardous substances.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryChemistryEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Battery Chemistry Entity",
        "rdfs:comment": {
            "@value": "<div>Detailed composition, including materials used in the cathode, anode, and electrolyte. All common cells have two electrodes and an electrolyte. The specific combination of materials used to make these components is called 'chemistry'.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryMaterialEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Battery Material Entity",
        "rdfs:comment": {
            "@value": "<div>Detailed composition, including materials used in the cathode, anode, and electrolyte.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:HazardousSubstanceEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Hazardous Substance Entity",
        "rdfs:comment": {
            "@value": "<div>Hazardous substances contained in the battery other than mercury, cadmium or lead. Substance as a chemical element and its compounds in the natural state or the result of a manufacturing process.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryLocationEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Battery Location Entity",
        "rdfs:comment": {
            "@value": "<div>Battery component that includes the material.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:PerformanceAndDurability",
        "@type": "rdfs:Class",
        "rdfs:label": "Performance and Durability",
        "rdfs:comment": {
            "@value": "<div>Battery performance and durability information including technical properties and condition.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryTechnicalPropertiesEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Battery Technical Properties Entity",
        "rdfs:comment": {
            "@value": "<div>Covers all capability related data attributes including rated capacity, power, energy, voltage ranges, internal resistance, and expected lifetime.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:BatteryConditionEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Battery Condition Entity",
        "rdfs:comment": {
            "@value": "<div>Covers all battery lifetime relevant properties including energy throughput, capacity fade, number of cycles, state of charge, and temperature information.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
