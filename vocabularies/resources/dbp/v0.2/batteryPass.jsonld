        "@type": "rdfs:Class",
        "rdfs:label": "Power Capability At Entity",
        "rdfs:comment": {
            "@value": "<div>Power capability measurement at specific state of charge percentage.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "bp:InternalResistanceEntity",
        "@type": "rdfs:Class",
        "rdfs:label": "Internal Resistance Entity",
        "rdfs:comment": {
            "@value": "<div>Internal resistance measurement for battery pack, module, or cell level.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "vocab",
            "@type": "jsonld:Context"
        }]
