    "@id": "https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#",
    "@type": "owl:Ontology",
    "dc:title": {
        "@value": "Digital Battery Passport Vocabulary",
        "@language": "en"
    },
    "dc:description": {
        "@value": "Vocabulary for the EU Battery Regulation Digital Product Passport, covering battery identity,\ncompliance, materials, carbon footprint, circularity, and performance and durability data\nas defined by the BatteryPass-Ready DataAttributeLongList v1.3 (March 2026).\n",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
    },
    "rdfs:seeAlso": "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX%3A32023R1542",
    "dc:date": "2026-06-10",
