    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:initialRoundTripEfficiency a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformancePublic ;
    rdfs:range xsd:decimal ;
    rdfs:label "Initial Round Trip Energy Efficiency" ;
    rdfs:comment """<div>Initial round trip energy efficiency of the battery as a percentage at beginning of life.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:roundTripEfficiencyAt50pct a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformancePublic ;
    rdfs:range xsd:decimal ;
    rdfs:label "Round Trip Efficiency at 50% Cycle Life" ;
    rdfs:comment """<div>Round trip energy efficiency at 50% of the expected cycle life as a percentage.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:initialInternalResistance a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformancePublic ;
    rdfs:range xsd:integer ;
    rdfs:label "Initial Internal Resistance" ;
    rdfs:comment """<div>Initial internal resistance of the battery cell and pack at beginning of life in milliohms.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:expectedLifetimeCycles a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformancePublic ;
    rdfs:range xsd:integer ;
    rdfs:label "Expected Lifetime Charge-Discharge Cycles" ;
    rdfs:comment """<div>Expected number of charge-discharge cycles before capacity drops below the exhaustion threshold.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:cycleLifeReferenceTest a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformancePublic ;
    rdfs:range xsd:string ;
    rdfs:label "Cycle-Life Reference Test" ;
    rdfs:comment """<div>Reference to the standard or test procedure used to determine cycle life.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:cRateCycleLifeTest a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformancePublic ;
    rdfs:range xsd:decimal ;
    rdfs:label "C-Rate of Cycle-Life Test" ;
    rdfs:comment """<div>C-rate applied during the cycle-life reference test.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:capacityThresholdExhaustion a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformancePublic ;
    rdfs:range xsd:decimal ;
    rdfs:label "Capacity Threshold for Exhaustion" ;
    rdfs:comment """<div>Capacity threshold below which the battery is considered exhausted, expressed as a percentage.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:tempRangeIdleLower a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformancePublic ;
    rdfs:range xsd:integer ;
    rdfs:label "Temperature Range Idle Lower Boundary" ;
    rdfs:comment """<div>Lower boundary of the temperature range for idle state storage in degrees Celsius.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:tempRangeIdleUpper a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformancePublic ;
    rdfs:range xsd:integer ;
    rdfs:label "Temperature Range Idle Upper Boundary" ;
    rdfs:comment """<div>Upper boundary of the temperature range for idle state storage in degrees Celsius.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:capacityFade a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range xsd:decimal ;
    rdfs:label "Capacity Fade" ;
    rdfs:comment """<div>Decrease in rated capacity over time as a percentage of the original capacity.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:remainingCapacity a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Remaining Capacity" ;
    rdfs:comment """<div>Current remaining capacity of the battery in ampere-hours (Ah).</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:remainingUsableBattEnergy a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Remaining Usable Battery Energy" ;
    rdfs:comment """<div>Current remaining usable energy of the battery in watt-hours (Wh).</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:stateOfCertifiedEnergy a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "State of Certified Energy" ;
    rdfs:comment """<div>State of certified energy (SOCE) as the ratio of remaining usable energy to certified usable energy.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:stateOfCharge a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "State of Charge" ;
    rdfs:comment """<div>Current state of charge (SoC) expressed as a percentage of remaining capacity.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:stateOfChargeDistributionHours a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:Distribution ;
    rdfs:label "State of Charge Distribution (Hours)" ;
    rdfs:comment """<div>Distribution of time spent in each state-of-charge interval over the measurement period,
expressed in cumulative hours. Interval min and max represent SoC percentage bands.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:stateOfChargeDistributionPercent a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:Distribution ;
    rdfs:label "State of Charge Distribution (Percent)" ;
    rdfs:comment """<div>Distribution of time spent in each state-of-charge interval over the measurement period,
expressed as cumulative percentage of total operating time. Interval min and max represent
SoC percentage bands.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:powerFade a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range xsd:decimal ;
    rdfs:label "Power Fade" ;
    rdfs:comment """<div>Decrease in power capability over time as a percentage of original power capability.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:remainingPowerCapabilityAt20SoC a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Remaining Power Capability at 20% SoC" ;
    rdfs:comment """<div>Current remaining power capability of the battery measured at 20% state of charge, in watts.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:remainingPowerCapabilityAt80SoC a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Remaining Power Capability at 80% SoC" ;
    rdfs:comment """<div>Current remaining power capability of the battery measured at 80% state of charge, in watts.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:roundTripEfficiencyFade a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range xsd:decimal ;
    rdfs:label "Energy Round Trip Efficiency Fade" ;
    rdfs:comment """<div>Decrease in round trip energy efficiency over time as a percentage.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:initialSelfDischargeRate a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range xsd:decimal ;
    rdfs:label "Initial Self-Discharge Rate" ;
    rdfs:comment """<div>Self-discharge rate at beginning of life expressed as a percentage per unit time.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:remainingRoundTripEfficiency a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Remaining Round Trip Energy Efficiency" ;
    rdfs:comment """<div>Current remaining round trip energy efficiency expressed as a percentage.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:currentSelfDischargeRate a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Current Self-Discharge Rate" ;
    rdfs:comment """<div>Current self-discharge rate expressed as a percentage per unit time.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:evolutionSelfDischargeRates a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Evolution of Self-Discharge Rates" ;
    rdfs:comment """<div>Historical evolution of self-discharge rates over the battery's service lifetime.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:internalResistanceIncrease a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range xsd:decimal ;
    rdfs:label "Internal Resistance Increase" ;
    rdfs:comment """<div>Increase in internal resistance over time expressed as a percentage of original resistance.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:expectedLifetimeYears a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range xsd:decimal ;
    rdfs:label "Expected Lifetime in Calendar Years" ;
    rdfs:comment """<div>Expected remaining lifetime of the battery in calendar years.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:numberOfFullCycles a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Number of Full Charging and Discharging Cycles" ;
    rdfs:comment """<div>Total number of full charge-discharge cycles completed by the battery to date.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:energyThroughput a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Energy Throughput" ;
    rdfs:comment """<div>Total energy throughput of the battery in watt-hours since first use.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:capacityThroughput a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Capacity Throughput" ;
    rdfs:comment """<div>Total charge throughput of the battery in ampere-hours since first use.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:temperatureInformation a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Temperature Information" ;
    rdfs:comment """<div>General temperature information about the battery's operating history.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:timeInExtremeTempsAbove a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Time in Extreme Temperatures Above Boundary" ;
    rdfs:comment """<div>Cumulative time the battery has spent in temperatures above the upper boundary, in hours.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:timeInExtremeTempsBelow a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Time in Extreme Temperatures Below Boundary" ;
    rdfs:comment """<div>Cumulative time the battery has spent in temperatures below the lower boundary, in hours.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:timeChargingExtremeTempsAbove a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Time Charging in Extreme Temperatures Above" ;
    rdfs:comment """<div>Cumulative time the battery has been charged at temperatures above the upper boundary, in hours.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:timeChargingExtremeTempsBelow a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Time Charging in Extreme Temperatures Below" ;
    rdfs:comment """<div>Cumulative time the battery has been charged at temperatures below the lower boundary, in hours.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:temperatureDistribution a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:Distribution ;
    rdfs:label "Temperature Distribution" ;
    rdfs:comment """<div>Distribution of time spent in each temperature interval over the measurement period,
expressed as cumulative percentage of total operating time. Interval min and max represent
temperature bands in degrees Celsius.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:deepDischargeEvents a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Number of Deep Discharge Events" ;
    rdfs:comment """<div>Total number of deep discharge events recorded for the battery.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:overchargeEvents a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Number of Overcharge Events" ;
    rdfs:comment """<div>Total number of overcharge events recorded for the battery.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:informationOnAccidents a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryPerformanceRestricted ;
    rdfs:range dbp:DynamicDataPoint ;
    rdfs:label "Information on Accidents" ;
    rdfs:comment """<div>URI linking to records of accidents or safety incidents involving the battery.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

# Class definitions
dbp:DynamicDataPoint a rdfs:Class ;
    rdfs:label "Dynamic Data Point" ;
    rdfs:comment """<div>Timestamped wrapper for a dynamic battery data point. Carries a scalar value of any type
alongside the timestamp of its most recent measurement or update.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:Distribution a rdfs:Class ;
    rdfs:label "Distribution" ;
    rdfs:comment """<div>Aggregated interval distribution of a battery measurement over a defined time period.
Represents histogram-style data suitable for bar chart visualisation.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:DistributionInterval a rdfs:Class ;
    rdfs:label "Distribution Interval" ;
    rdfs:comment """<div>One interval bucket in a distribution. Boundary convention: [min, max) for all buckets
except the last which uses a closed upper bound [min, max].</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:PostalAddress a rdfs:Class ;
    rdfs:label "Postal Address" ;
    rdfs:comment """<div>A structured postal address including postal code, street address, and country.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:ContactInformation a rdfs:Class ;
    rdfs:label "Contact Information" ;
    rdfs:comment """<div>Contact details for an organisation including phone, email, and website.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:CompanyInformation a rdfs:Class ;
    rdfs:label "Company Information" ;
    rdfs:comment """<div>Complete company profile including unique identifier, name, contact information, and postal address.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:DPPInfo a rdfs:Class ;
    rdfs:label "DPP Information" ;
    rdfs:comment """<div>Digital Product Passport metadata including schema version, granularity level, DPP status,
and last updated timestamp.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryAttributes a rdfs:Class ;
    rdfs:label "Battery Attributes" ;
    rdfs:comment """<div>General battery attributes including warranty period, battery category, and battery mass.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryIdentifiers a rdfs:Class ;
    rdfs:label "Battery Identifiers" ;
    rdfs:comment """<div>Publicly accessible battery identifiers including battery model identifier, unique battery
identifier, serial number, and unique DPP identifier.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:ProductData a rdfs:Class ;
    rdfs:label "Product Data" ;
    rdfs:comment """<div>Publicly accessible product data including economic operator information, manufacturer
information, manufacturing place, and manufacturing date.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:GeneralInformationPublic a rdfs:Class ;
    rdfs:label "General Information (Public)" ;
    rdfs:comment """<div>Public general information container grouping DPP metadata, battery attributes,
battery identifiers, and product data.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:OperatorIdentifiers a rdfs:Class ;
    rdfs:label "Operator Identifiers" ;
    rdfs:comment """<div>Restricted identifiers for the manufacturer, manufacturing facility, and economic operator.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:RestrictedProductData a rdfs:Class ;
    rdfs:label "Restricted Product Data" ;
    rdfs:comment """<div>Restricted product data including date of putting into service and battery status,
accessible only by notified bodies and market surveillance authorities.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:GeneralInformationRestricted a rdfs:Class ;
    rdfs:label "General Information (Restricted)" ;
    rdfs:comment """<div>Restricted general information including operator identifiers and restricted product data,
accessible only by notified bodies and market surveillance authorities.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:Label a rdfs:Class ;
    rdfs:label "Label" ;
    rdfs:comment """<div>A regulatory label or symbol with its symbol code, human-readable meaning, and subject matter.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryCompliancePublic a rdfs:Class ;
    rdfs:label "Battery Compliance (Public)" ;
    rdfs:comment """<div>Public compliance information including regulatory symbols and labels, extinguishing agent,
and EU declaration of conformity.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryComplianceRestricted a rdfs:Class ;
    rdfs:label "Battery Compliance (Restricted)" ;
    rdfs:comment """<div>Restricted compliance information including test report results, accessible only by
notified bodies and market surveillance authorities.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:SupplyChainDueDiligence a rdfs:Class ;
    rdfs:label "Supply Chain Due Diligence" ;
    rdfs:comment """<div>Supply chain due diligence information including the due diligence report, third-party
assurances, and supply chain indices.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:HazardousSubstance a rdfs:Class ;
    rdfs:label "Hazardous Substance" ;
    rdfs:comment """<div>A hazardous substance present in the battery, identified by name and its impact on
human health and the environment.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryChemistry a rdfs:Class ;
    rdfs:label "Battery Chemistry" ;
    rdfs:comment """<div>The electrochemical technology of the battery identified by its full clear name and abbreviated short name.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryMaterialsPublic a rdfs:Class ;
    rdfs:label "Battery Materials (Public)" ;
    rdfs:comment """<div>Publicly accessible battery materials information including battery chemistry,
critical raw materials, and hazardous substances.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryMaterialLocation a rdfs:Class ;
    rdfs:label "Battery Material Location" ;
    rdfs:comment """<div>The location of a material within the battery assembly, identified by component ID and component name.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryMaterial a rdfs:Class ;
    rdfs:label "Battery Material" ;
    rdfs:comment """<div>A single material entry in the battery composition, including identifier, name, mass,
share, critical raw material flag, and location within the battery.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryMaterialsRestricted a rdfs:Class ;
    rdfs:label "Battery Materials (Restricted)" ;
    rdfs:comment """<div>Restricted battery materials information including the detailed materials composition list,
accessible to operators, recyclers, and repairers.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryCarbonFootprint a rdfs:Class ;
    rdfs:label "Battery Carbon Footprint" ;
    rdfs:comment """<div>Carbon footprint data for the battery including lifecycle phase contributions, performance class,
and a link to the full carbon footprint study.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:EndUserInformation a rdfs:Class ;
    rdfs:label "End-User Information" ;
    rdfs:comment """<div>Information for end users about waste prevention, separate collection obligations,
and battery collection, second life, and end-of-life processes.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:RecycledRenewableContent a rdfs:Class ;
    rdfs:label "Recycled and Renewable Content" ;
    rdfs:comment """<div>Recycled and renewable content shares for key materials including nickel, cobalt,
lithium, lead, and general renewable content.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryCircularityPublic a rdfs:Class ;
    rdfs:label "Battery Circularity (Public)" ;
    rdfs:comment """<div>Public circularity information including end-user guidance and recycled and
renewable content shares.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryCircularityPrivate a rdfs:Class ;
    rdfs:label "Battery Circularity (Restricted)" ;
    rdfs:comment """<div>Restricted circularity information including dismantling manuals, part numbers,
spare parts sources, and safety measures.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryPerformancePublic a rdfs:Class ;
    rdfs:label "Battery Performance (Public)" ;
    rdfs:comment """<div>Public battery performance and durability data covering capacity, energy, voltage, power
capability, round trip efficiency, internal resistance, lifetime, and temperature conditions.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryPerformanceRestricted a rdfs:Class ;
    rdfs:label "Battery Performance (Restricted)" ;
    rdfs:comment """<div>Restricted dynamic battery performance and durability data covering capacity fade, remaining
capacity and energy, state of charge, power fade, efficiency fade, internal resistance
increase, lifetime counters, temperature distributions, and negative events.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.



# Definitions of datatypes
dbp:PerformanceClass a rdfs:Datatype ;
    rdfs:subClassOf xsd:string ;
    owl:onDatatype xsd:string ;
    owl:withRestrictions ([xsd:pattern "A|B|C|D|E|F|G"]) ;
    rdfs:label "Performance Class" ;
    rdfs:comment """<div>Carbon footprint performance class assigned to a battery model, ranging from A (best) to G (worst).</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

