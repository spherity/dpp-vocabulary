dbp:CompanyInformation a rdfs:Class ;
    rdfs:label "Company Information" ;
    rdfs:comment """<div>Complete company profile including unique identifier, name, contact information, and postal address.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:DPPInfo a rdfs:Class ;
    rdfs:label "DPP Information" ;
    rdfs:comment """<div>Digital Product Passport metadata including schema version, granularity level, DPP status,
and last updated timestamp.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryAttributes a rdfs:Class ;
    rdfs:label "Battery Attributes" ;
    rdfs:comment """<div>General battery attributes including warranty period, battery category, and battery mass.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryIdentifiers a rdfs:Class ;
    rdfs:label "Battery Identifiers" ;
    rdfs:comment """<div>Publicly accessible battery identifiers including battery model identifier, unique battery
identifier, serial number, and unique DPP identifier.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:ProductData a rdfs:Class ;
    rdfs:label "Product Data" ;
    rdfs:comment """<div>Publicly accessible product data including economic operator information, manufacturer
information, manufacturing place, and manufacturing date.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:GeneralInformationPublic a rdfs:Class ;
    rdfs:label "General Information (Public)" ;
    rdfs:comment """<div>Public general information container grouping DPP metadata, battery attributes,
battery identifiers, and product data.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:OperatorIdentifiers a rdfs:Class ;
    rdfs:label "Operator Identifiers" ;
    rdfs:comment """<div>Restricted identifiers for the manufacturer, manufacturing facility, and economic operator.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:RestrictedProductData a rdfs:Class ;
    rdfs:label "Restricted Product Data" ;
    rdfs:comment """<div>Restricted product data including date of putting into service and battery status,
accessible only by notified bodies and market surveillance authorities.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:GeneralInformationRestricted a rdfs:Class ;
    rdfs:label "General Information (Restricted)" ;
    rdfs:comment """<div>Restricted general information including operator identifiers and restricted product data,
accessible only by notified bodies and market surveillance authorities.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:Label a rdfs:Class ;
    rdfs:label "Label" ;
    rdfs:comment """<div>A regulatory label or symbol with its symbol code, human-readable meaning, and subject matter.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryCompliancePublic a rdfs:Class ;
    rdfs:label "Battery Compliance (Public)" ;
    rdfs:comment """<div>Public compliance information including regulatory symbols and labels, extinguishing agent,
and EU declaration of conformity.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryComplianceRestricted a rdfs:Class ;
    rdfs:label "Battery Compliance (Restricted)" ;
    rdfs:comment """<div>Restricted compliance information including test report results, accessible only by
notified bodies and market surveillance authorities.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:SupplyChainDueDiligence a rdfs:Class ;
    rdfs:label "Supply Chain Due Diligence" ;
    rdfs:comment """<div>Supply chain due diligence information including the due diligence report, third-party
assurances, and supply chain indices.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:HazardousSubstance a rdfs:Class ;
    rdfs:label "Hazardous Substance" ;
    rdfs:comment """<div>A hazardous substance present in the battery, identified by name and its impact on
human health and the environment.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryChemistry a rdfs:Class ;
    rdfs:label "Battery Chemistry" ;
    rdfs:comment """<div>The electrochemical technology of the battery identified by its full clear name and abbreviated short name.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryMaterialsPublic a rdfs:Class ;
    rdfs:label "Battery Materials (Public)" ;
    rdfs:comment """<div>Publicly accessible battery materials information including battery chemistry,
critical raw materials, and hazardous substances.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryMaterialLocation a rdfs:Class ;
    rdfs:label "Battery Material Location" ;
    rdfs:comment """<div>The location of a material within the battery assembly, identified by component ID and component name.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryMaterial a rdfs:Class ;
    rdfs:label "Battery Material" ;
    rdfs:comment """<div>A single material entry in the battery composition, including identifier, name, mass,
share, critical raw material flag, and location within the battery.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryMaterialsRestricted a rdfs:Class ;
    rdfs:label "Battery Materials (Restricted)" ;
    rdfs:comment """<div>Restricted battery materials information including the detailed materials composition list,
accessible to operators, recyclers, and repairers.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryCarbonFootprint a rdfs:Class ;
    rdfs:label "Battery Carbon Footprint" ;
    rdfs:comment """<div>Carbon footprint data for the battery including lifecycle phase contributions, performance class,
and a link to the full carbon footprint study.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:EndUserInformation a rdfs:Class ;
    rdfs:label "End-User Information" ;
    rdfs:comment """<div>Information for end users about waste prevention, separate collection obligations,
and battery collection, second life, and end-of-life processes.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:RecycledRenewableContent a rdfs:Class ;
    rdfs:label "Recycled and Renewable Content" ;
    rdfs:comment """<div>Recycled and renewable content shares for key materials including nickel, cobalt,
lithium, lead, and general renewable content.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryCircularityPublic a rdfs:Class ;
    rdfs:label "Battery Circularity (Public)" ;
    rdfs:comment """<div>Public circularity information including end-user guidance and recycled and
renewable content shares.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryCircularityPrivate a rdfs:Class ;
    rdfs:label "Battery Circularity (Restricted)" ;
    rdfs:comment """<div>Restricted circularity information including dismantling manuals, part numbers,
spare parts sources, and safety measures.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:CapacityEnergyVoltagePublic a rdfs:Class ;
    rdfs:label "Capacity, Energy and Voltage (Public)" ;
    rdfs:comment """<div>Public static battery performance data for capacity, energy, and voltage including
rated capacity, certified usable energy, and minimum, maximum, and nominal voltages.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:PowerCapabilityPublic a rdfs:Class ;
    rdfs:label "Power Capability (Public)" ;
    rdfs:comment """<div>Public static power capability data including original power capability, maximum
permitted battery power, and ratio of nominal power to battery energy.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:RoundTripEfficiencyPublic a rdfs:Class ;
    rdfs:label "Round Trip Efficiency (Public)" ;
    rdfs:comment """<div>Public static round trip energy efficiency data including initial efficiency and
efficiency at 50% of the expected cycle life.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:InternalResistancePublic a rdfs:Class ;
    rdfs:label "Internal Resistance (Public)" ;
    rdfs:comment """<div>Public static initial internal resistance of the battery cell and pack at beginning of life.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryLifetimePublic a rdfs:Class ;
    rdfs:label "Battery Lifetime (Public)" ;
    rdfs:comment """<div>Public static battery lifetime data including expected charge-discharge cycles,
cycle-life reference test, C-rate, and capacity threshold for exhaustion.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:TemperatureConditionsPublic a rdfs:Class ;
    rdfs:label "Temperature Conditions (Public)" ;
    rdfs:comment """<div>Public static temperature range boundaries for idle state battery storage and operation.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryPerformancePublic a rdfs:Class ;
    rdfs:label "Battery Performance (Public)" ;
    rdfs:comment """<div>Public battery performance and durability data container grouping capacity, power,
efficiency, internal resistance, lifetime, and temperature sub-sections.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:CapacityEnergyVoltageRestricted a rdfs:Class ;
    rdfs:label "Capacity, Energy and Voltage (Restricted)" ;
    rdfs:comment """<div>Dynamic restricted capacity and energy data including capacity fade, remaining capacity,
remaining usable energy, state of certified energy, and state of charge.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:PowerCapabilityRestricted a rdfs:Class ;
    rdfs:label "Power Capability (Restricted)" ;
    rdfs:comment """<div>Dynamic restricted power capability data including power fade and remaining power capability.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:RoundTripEfficiencyRestricted a rdfs:Class ;
    rdfs:label "Round Trip Efficiency (Restricted)" ;
    rdfs:comment """<div>Dynamic restricted round trip efficiency data including efficiency fade, initial and current
self-discharge rates, remaining efficiency, and evolution of self-discharge rates.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:InternalResistanceRestricted a rdfs:Class ;
    rdfs:label "Internal Resistance (Restricted)" ;
    rdfs:comment """<div>Dynamic restricted internal resistance data recording resistance increase over lifetime.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryLifetimeRestricted a rdfs:Class ;
    rdfs:label "Battery Lifetime (Restricted)" ;
    rdfs:comment """<div>Dynamic restricted battery lifetime data including expected remaining lifetime in years,
number of full cycles completed, energy throughput, and capacity throughput.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:TemperatureConditionsRestricted a rdfs:Class ;
    rdfs:label "Temperature Conditions (Restricted)" ;
    rdfs:comment """<div>Dynamic restricted temperature condition data including time spent in extreme temperatures
during operation and charging.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:NegativeEvents a rdfs:Class ;
    rdfs:label "Negative Events" ;
    rdfs:comment """<div>Dynamic restricted data on adverse battery events including deep discharge events,
overcharge events, and information on accidents.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:BatteryPerformanceRestricted a rdfs:Class ;
    rdfs:label "Battery Performance (Restricted)" ;
    rdfs:comment """<div>Restricted dynamic battery performance data container grouping capacity, power, efficiency,
internal resistance, lifetime, temperature, and negative event sub-sections.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.



# Definitions of datatypes
dbp:PerformanceClass a rdfs:Datatype ;
    rdfs:subClassOf xsd:string ;
    owl:onDatatype xsd:string ;
    owl:withRestrictions ([xsd:pattern "A|B|C|D|E|F|G"]) ;
    rdfs:label "Performance Class" ;
    rdfs:comment """<div>Carbon footprint performance class assigned to a battery model, ranging from A (best) to G (worst).</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

