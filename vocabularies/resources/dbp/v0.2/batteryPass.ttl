@prefix dbp: <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix jsonld: <http://www.w3.org/ns/json-ld#> .
@prefix schema: <http://schema.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .

# Ontology definition
dbp: a owl:Ontology ;
    dc:title """Digital Battery Passport Vocabulary"""@en ;
    dc:description """Vocabulary for the EU Battery Regulation Digital Product Passport, covering battery identity,
compliance, materials, carbon footprint, circularity, and performance and durability data
as defined by the BatteryPass-Ready DataAttributeLongList v1.3 (March 2026).
"""^^rdf:HTML ;
    rdfs:seeAlso <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX%3A32023R1542> ;
    dc:date "2026-06-11"^^xsd:date ;
.

# Property definitions
dbp:dynamicDataPointValue a rdf:Property ;
    rdfs:domain dbp:DynamicDataPoint ;
    rdfs:range rdfs:Literal ;
    rdfs:label "Value" ;
    rdfs:comment """<div>The scalar value of the dynamic data point. May be any literal type (numeric, string,
boolean, URI string, etc.); type validation is delegated to the associated JSON Schema.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:dynamicDataPointObservedAt a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:DynamicDataPoint ;
    rdfs:range xsd:dateTime ;
    rdfs:label "Observed At" ;
    rdfs:comment """<div>Timestamp of the most recent measurement or update for this dynamic data point.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:distributionFromTimestamp a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:Distribution ;
    rdfs:range xsd:dateTime ;
    rdfs:label "From Timestamp" ;
    rdfs:comment """<div>Start of the measurement period covered by this distribution.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:distributionToTimestamp a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:Distribution ;
    rdfs:range xsd:dateTime ;
    rdfs:label "To Timestamp" ;
    rdfs:comment """<div>End of the measurement period covered by this distribution.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:distributionIntervals a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:Distribution ;
    rdfs:range dbp:DistributionInterval ;
    rdfs:label "Intervals" ;
    rdfs:comment """<div>Collection of interval buckets comprising the distribution.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:distributionIntervalMin a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:DistributionInterval ;
    rdfs:range xsd:decimal ;
    rdfs:label "Minimum" ;
    rdfs:comment """<div>Lower bound of the interval bucket (inclusive).</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:distributionIntervalMax a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:DistributionInterval ;
    rdfs:range xsd:decimal ;
    rdfs:label "Maximum" ;
    rdfs:comment """<div>Upper bound of the interval bucket. Exclusive for all buckets except the last, which is inclusive.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:distributionIntervalValue a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:DistributionInterval ;
    rdfs:range xsd:decimal ;
    rdfs:label "Value" ;
    rdfs:comment """<div>Aggregated value for this interval bucket over the measurement period. Unit is defined by
the parent distribution property (e.g. cumulative hours or cumulative percentage of time).</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:postalCode a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:PostalAddress ;
    rdfs:range xsd:string ;
    rdfs:label "Postal Code" ;
    rdfs:comment """<div>The postal or ZIP code of the address.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:streetAddress a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:PostalAddress ;
    rdfs:range xsd:string ;
    rdfs:label "Street Address" ;
    rdfs:comment """<div>The full street address including building number.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:country a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:PostalAddress ;
    rdfs:range xsd:string ;
    rdfs:label "Country" ;
    rdfs:comment """<div>The country of the address, preferably as an ISO 3166-1 alpha-2 country code.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:phone a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:ContactInformation ;
    rdfs:range xsd:string ;
    rdfs:label "Phone" ;
    rdfs:comment """<div>The telephone number for the contact.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:email a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:ContactInformation ;
    rdfs:range xsd:string ;
    rdfs:label "Email" ;
    rdfs:comment """<div>The email address for the contact.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:website a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:ContactInformation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "Website" ;
    rdfs:comment """<div>The URL of the organisation's website.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:identifier a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:CompanyInformation ;
    rdfs:range xsd:string ;
    rdfs:label "Identifier" ;
    rdfs:comment """<div>Unique identifier for the company or operator.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:legalName a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:CompanyInformation ;
    rdfs:range xsd:string ;
    rdfs:label "Legal Name" ;
    rdfs:comment """<div>Legal name of the company or operator.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:contact a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:CompanyInformation ;
    rdfs:range dbp:ContactInformation ;
    rdfs:label "Contact" ;
    rdfs:comment """<div>Contact details for the company or operator.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:address a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:CompanyInformation ;
    rdfs:range dbp:PostalAddress ;
    rdfs:label "Address" ;
    rdfs:comment """<div>Registered postal address of the company or operator.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:registeredTradeNameOrTrademark a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:CompanyInformation ;
    rdfs:range xsd:string ;
    rdfs:label "Registered Trade Name or Trademark" ;
    rdfs:comment """<div>Registered trade name or registered trademark of the manufacturer or economic operator, where applicable.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:schemaVersion a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:DPPInfo ;
    rdfs:range xsd:string ;
    rdfs:label "Schema Version" ;
    rdfs:comment """<div>Version of the DPP data schema used for this battery passport instance.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:dppGranularity a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:DPPInfo ;
    rdfs:range xsd:string ;
    rdfs:label "DPP Granularity" ;
    rdfs:comment """<div>Granularity level of the DPP — model, batch, site, or individual battery.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:dppStatus a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:DPPInfo ;
    rdfs:range xsd:string ;
    rdfs:label "DPP Status" ;
    rdfs:comment """<div>Current lifecycle status of the DPP (e.g. active, withdrawn, updated).</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:lastUpdated a rdf:Property, owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:label "Last Updated" ;
    rdfs:comment """<div>Timestamp of the most recent update to the data record.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:warrantyPeriod a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryAttributes ;
    rdfs:range xsd:date ;
    rdfs:label "Warranty Period" ;
    rdfs:comment """<div>Date until which the manufacturer warranty for the battery is valid.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:batteryCategory a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryAttributes ;
    rdfs:range xsd:string ;
    rdfs:label "Battery Category" ;
    rdfs:comment """<div>Category of the battery as defined by the EU Battery Regulation
(e.g. EV, LMT, industrial, stationary).</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:batteryMass a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryAttributes ;
    rdfs:range xsd:decimal ;
    rdfs:label "Battery Mass" ;
    rdfs:comment """<div>Total mass of the battery in kilograms.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:batteryModelIdentifier a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryIdentifiers ;
    rdfs:range xsd:string ;
    rdfs:label "Battery Model Identifier" ;
    rdfs:comment """<div>Unique identifier for the battery model, assigned at model level.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:uniqueBatteryIdentifier a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryIdentifiers ;
    rdfs:range xsd:anyURI ;
    rdfs:label "Unique Battery Identifier" ;
    rdfs:comment """<div>Unique identifier for the individual battery unit expressed as a URI.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:serialNumber a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryIdentifiers ;
    rdfs:range xsd:string ;
    rdfs:label "Serial Number" ;
    rdfs:comment """<div>Manufacturer-assigned serial number for the individual battery unit.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:uniqueDPPIdentifier a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryIdentifiers ;
    rdfs:range xsd:anyURI ;
    rdfs:label "Unique DPP Identifier" ;
    rdfs:comment """<div>Unique identifier for this Digital Product Passport expressed as a URI.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:economicOperator a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:ProductData ;
    rdfs:range dbp:CompanyInformation ;
    rdfs:label "Economic Operator" ;
    rdfs:comment """<div>Information about the economic operator responsible for placing the battery on the market.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:manufacturer a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:ProductData ;
    rdfs:range dbp:CompanyInformation ;
    rdfs:label "Manufacturer" ;
    rdfs:comment """<div>Information about the battery manufacturer.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:manufacturingPlace a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:ProductData ;
    rdfs:range dbp:PostalAddress ;
    rdfs:label "Manufacturing Place" ;
    rdfs:comment """<div>Postal address of the manufacturing facility.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:manufacturingDate a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:ProductData ;
    rdfs:range xsd:date ;
    rdfs:label "Manufacturing Date" ;
    rdfs:comment """<div>Date on which the battery was manufactured.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:general a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:GeneralInformationPublic ;
    rdfs:range dbp:BatteryAttributes ;
    rdfs:label "General" ;
    rdfs:comment """<div>General battery attributes including warranty period, category, and mass.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:identifiers a rdf:Property ;
    rdfs:label "Identifiers" ;
    rdfs:comment """<div>Identifiers sub-section. In the public context points to BatteryIdentifiers;
in the restricted context points to OperatorIdentifiers.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:productData a rdf:Property ;
    rdfs:label "Product Data" ;
    rdfs:comment """<div>Product data sub-section. In the public context points to ProductData;
in the restricted context points to RestrictedProductData.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:manufacturerId a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:OperatorIdentifiers ;
    rdfs:range xsd:string ;
    rdfs:label "Manufacturer ID" ;
    rdfs:comment """<div>Unique identifier for the battery manufacturer.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:facilityId a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:OperatorIdentifiers ;
    rdfs:range xsd:string ;
    rdfs:label "Facility ID" ;
    rdfs:comment """<div>Unique identifier for the manufacturing facility.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:economicOperatorId a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:OperatorIdentifiers ;
    rdfs:range xsd:string ;
    rdfs:label "Economic Operator ID" ;
    rdfs:comment """<div>Unique identifier for the economic operator.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:dateOfPuttingIntoService a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:RestrictedProductData ;
    rdfs:range xsd:date ;
    rdfs:label "Date of Putting Into Service" ;
    rdfs:comment """<div>Date on which the battery was first put into service.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:batteryStatus a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:RestrictedProductData ;
    rdfs:range xsd:string ;
    rdfs:label "Battery Status" ;
    rdfs:comment """<div>Current operational status of the battery (e.g. original, repurposed, remanufactured, waste).</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:symbol a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:Label ;
    rdfs:range xsd:string ;
    rdfs:label "Symbol" ;
    rdfs:comment """<div>The regulatory symbol code or icon reference.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:meaning a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:Label ;
    rdfs:range xsd:string ;
    rdfs:label "Meaning" ;
    rdfs:comment """<div>Human-readable explanation of the symbol's meaning.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:subject a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:Label ;
    rdfs:range xsd:string ;
    rdfs:label "Subject" ;
    rdfs:comment """<div>The subject matter or topic addressed by this label or symbol.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:separateCollectionSymbol a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryCompliancePublic ;
    rdfs:range xsd:boolean ;
    rdfs:label "Separate Collection Symbol" ;
    rdfs:comment """<div>Symbol indicating that the battery must be separately collected at end of life.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:cadmiumSymbol a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryCompliancePublic ;
    rdfs:range xsd:boolean ;
    rdfs:label "Cadmium Symbol" ;
    rdfs:comment """<div>Indicates presence of cadmium above the regulatory threshold of 0.004% by weight.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:leadSymbol a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryCompliancePublic ;
    rdfs:range xsd:boolean ;
    rdfs:label "Lead Symbol" ;
    rdfs:comment """<div>Indicates presence of lead above the regulatory threshold of 0.004% by weight.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:carbonFootprintLabel a rdf:Property, owl:ObjectProperty ;
    rdfs:domain dbp:BatteryCompliancePublic ;
    rdfs:range dbp:Label ;
    rdfs:label "Carbon Footprint Label" ;
    rdfs:comment """<div>Label displaying the carbon footprint performance class assigned to the battery model.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:extinguishingAgent a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryCompliancePublic ;
    rdfs:range xsd:string ;
    rdfs:label "Extinguishing Agent" ;
    rdfs:comment """<div>The type of extinguishing agent suitable for use in case of battery fire.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:euDeclarationConformity a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryCompliancePublic ;
    rdfs:range xsd:anyURI ;
    rdfs:label "EU Declaration of Conformity" ;
    rdfs:comment """<div>URI linking to the EU declaration of conformity document for this battery.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:testReportResults a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:BatteryComplianceRestricted ;
    rdfs:range xsd:anyURI ;
    rdfs:label "Test Report Results" ;
    rdfs:comment """<div>URI linking to the results of conformity test reports.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://dpp.vocabulary.spherity.com/dbp/v0.2/batteryPass#> ;
    vs:term_status "stable" ;
.

dbp:dueDiligenceReport a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain dbp:SupplyChainDueDiligence ;
    rdfs:range xsd:anyURI ;
