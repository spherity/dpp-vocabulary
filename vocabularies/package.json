{
  "dependencies": {
    "glob": "^11.0.0",
    "jsonld": "^8.3.2"
  },
  "engines": {
    "node": ">=18.0"
  },
  "name": "@spherity/dpp-vocabulary",
  "packageManager": "pnpm@9.11.0",
  "scripts": {
    "build": "rsync -av --delete --exclude='*.yml' --exclude='dbp-template.html' resources/dbp/ public/dbp/",
