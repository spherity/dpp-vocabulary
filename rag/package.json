{
    "name": "batterypass-rag",
    "version": "0.1.0",
    "description": "RAG ingestion pipeline for the Battery Pass vocabulary generation",
    "type": "module",
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "build": "tsc",
        "ingest": "node --import tsx/esm src/ingest.ts",
        "typecheck": "tsc --noEmit",
        "query": "node --import tsx/esm src/query.ts",
        "reset": "node --import tsx/esm src/reset.ts",
        "wg:config": "flyctl wireguard create spherity-vera fra rag-wg fly-wireguard.conf",
        "wg:ingest": "./wg-ingest.sh",
        "wg:query": "./wg-query.sh",
        "wg:reset": "./wg-reset.sh"
    },
    "dependencies": {
        "@upstash/vector": "^1.2.0",
        "csv-parse": "^5.6.0",
        "dotenv": "^16.4.7",
        "exceljs": "^4.4.0",
        "minimatch": "^10.0.1",
        "pdf-parse": "^1.1.1"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/pdf-parse": "^1.1.4",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3"
    }
}